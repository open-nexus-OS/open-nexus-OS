// Phone override: a compact single-column detail (no heading row).

Page DetailPage {
    Stack {
        Text($state.selected).textSize(base)
        Button { label: @t("common.back") }
        on Tap -> navigate("/")
    }
    .padding(2)
    .gap(2)
}
