{
  "grammars": [
    {
      "name": "nx",
      "camelcase": "Nx",
      "scope": "source.nx",
      "path": ".",
      "file-types": ["nx"],
      "highlights": "queries/highlights.scm",
      "folds": "queries/folds.scm",
      "indents": "queries/indents.scm",
      "injection-regex": "^nx$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Apache-2.0",
    "description": "Tree-sitter grammar for the .nx DSL (Open Nexus OS)",
    "authors": [{ "name": "Open Nexus OS Contributors" }],
    "links": {
      "repository": "https://github.com/open-nexus-OS/open-nexus-OS"
    }
  }
}
