{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-nexus-os.dev/schemas/config/v1/dsoftbus.schema.json",
  "title": "dsoftbus config v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "transport": {
      "type": "string",
      "enum": ["tcp", "quic", "auto"]
    },
    "max_peers": {
      "type": "integer",
      "minimum": 1,
      "maximum": 4096
    }
  }
}
