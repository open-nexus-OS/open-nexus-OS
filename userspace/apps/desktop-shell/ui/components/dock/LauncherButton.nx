//
// The round floating launcher button (handoff landscape dock: panel glass,
// bare glyph). Tap handler attaches at the use site (→ /launcher).

Component LauncherButton {
    Stack {
        Icon { symbol: "square.grid" }
            .fg(onSurface)
    }
    .width(44)
    .height(44)
    .material(panel)
    .rounded(full)
    .align(center)
    .justify(center)
}
